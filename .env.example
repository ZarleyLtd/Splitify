# Supabase Edge Function secrets (set in Dashboard or `supabase secrets set`)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GEMINI_API_KEY=your-gemini-api-key
# Direct Postgres URI (port 5432) — required for atomic claim submission
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# One-time migration from Google Apps Script (local env only)
LEGACY_API_URL=https://script.google.com/macros/s/.../exec
